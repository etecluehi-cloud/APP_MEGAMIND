<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_resumo.xml
    Aba "Resumo" dentro da DetalhesActivity.
    Exibe um texto longo vindo do Firebase, com scroll.

    No Fragment Java (ResumoFragment.java), preencha assim:
        TextView txtResumo = view.findViewById(R.id.txtResumo);
        txtResumo.setText(conteudo.getResumo());
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_claro">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="20dp"
        android:paddingBottom="24dp">

        <!-- Título da seção -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sobre este conteúdo"
            android:textColor="@color/roxo_primario"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <!-- Linha decorativa roxa -->
        <View
            android:layout_width="40dp"
            android:layout_height="3dp"
            android:background="@color/roxo_primario"
            android:layout_marginBottom="16dp" />

        <!--
            Texto do resumo vindo do Firebase.
            Suporta textos longos com scroll.
        -->
        <TextView
            android:id="@+id/txtResumo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Carregando resumo..."
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="15sp"
            android:lineSpacingMultiplier="1.6"
            android:textIsSelectable="true" />

    </LinearLayout>

</ScrollView>