<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Home">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?android:attr/windowBackground">

        <View
            android:id="@+id/header"
            android:layout_width="0dp"
            android:layout_height="184dp"
            android:background="@drawable/bg_header"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/imgPerfil"
            android:layout_width="1dp"
            android:layout_height="1dp"
            android:layout_marginStart="1dp"
            android:layout_marginTop="1dp"
            android:alpha="0"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_user"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/bemvindoa"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="26dp"
            android:layout_marginTop="92dp"
            android:layout_marginEnd="12dp"
            android:fontFamily="@font/poppins_bold"
            android:text="Bem-vindo(a)"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            app:layout_constraintEnd_toStartOf="@id/imgLogo2"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/header" />

        <TextView
            android:id="@+id/txtNomeU"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:fontFamily="@font/poppins"
            android:text="Nome do estudante"
            android:textColor="#EFE3FF"
            android:textSize="13.5sp"
            app:layout_constraintEnd_toEndOf="@id/bemvindoa"
            app:layout_constraintStart_toStartOf="@id/bemvindoa"
            app:layout_constraintTop_toBottomOf="@id/bemvindoa" />

        <ImageButton
            android:id="@+id/btnMenu"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginStart="24dp"
            android:layout_marginTop="24dp"
            android:background="@android:color/transparent"
            android:contentDescription="Menu"
            android:padding="8dp"
            android:src="@drawable/ic_menu"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/header"
            app:tint="#FFFFFF" />

        <ImageView
            android:id="@+id/imgLogo2"
            android:layout_width="148dp"
            android:layout_height="160dp"
            android:layout_marginTop="10dp"
            android:layout_marginEnd="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/logo" />

        <TextView
            android:id="@+id/textView4"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="24dp"
            android:fontFamily="@font/poppins_bold"
            android:text="Conteúdos"
            android:textColor="@color/cor_texto"
            android:textSize="27sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/header" />

        <TextView
            android:id="@+id/txtSubConteudos"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:fontFamily="@font/poppins"
            android:text="Escolha o que voce quer praticar agora"
            android:textColor="@color/cor_texto"
            android:textSize="12.5sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/textView4" />

        <LinearLayout
            android:id="@+id/gridConteudos"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="22dp"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="22dp"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/txtSubConteudos">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="3">

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                    <ImageView android:id="@+id/btnConteudoMat" android:layout_width="82dp" android:layout_height="82dp" android:background="@drawable/bg_botao_conteudo" android:clickable="true" android:focusable="true" android:foreground="?attr/selectableItemBackground" android:padding="19dp" android:src="@drawable/ic_calculadora" app:tint="#FFFFFF" />

                    <TextView
                        android:id="@+id/txtConteudoMat"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="7dp"
                        android:fontFamily="@font/poppins"
                        android:gravity="center"
                        android:text="Conteúdo\nMatemática"
                        android:textColor="@color/cor_texto"
                        android:textSize="12.5sp" />
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                    <ImageView android:id="@+id/btnConteudoPort" android:layout_width="82dp" android:layout_height="82dp" android:background="@drawable/bg_botao_conteudo" android:clickable="true" android:focusable="true" android:foreground="?attr/selectableItemBackground" android:padding="19dp" android:src="@drawable/ic_livro" app:tint="#FFFFFF" />

                    <TextView
                        android:id="@+id/txtConteudoPort"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="7dp"
                        android:fontFamily="@font/poppins"
                        android:gravity="center"
                        android:text="Conteúdo\nPortuguês"
                        android:textColor="@color/cor_texto"
                        android:textSize="12.5sp" />
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                    <ImageView android:id="@+id/btnConteudoRed" android:layout_width="82dp" android:layout_height="82dp" android:background="@drawable/bg_botao_conteudo" android:clickable="true" android:focusable="true" android:foreground="?attr/selectableItemBackground" android:padding="19dp" android:src="@drawable/ic_redacao" app:tint="#FFFFFF" />

                    <TextView
                        android:id="@+id/txtConteudoRed"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="7dp"
                        android:fontFamily="@font/poppins"
                        android:gravity="center"
                        android:text="Conteúdo\nRedação"
                        android:textColor="@color/cor_texto"
                        android:textSize="12.5sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="36dp"
                android:orientation="horizontal"
                android:weightSum="3">

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                    <ImageView android:id="@+id/btnQuestMat" android:layout_width="82dp" android:layout_height="82dp" android:background="@drawable/bg_botao_conteudo" android:clickable="true" android:focusable="true" android:foreground="?attr/selectableItemBackground" android:padding="19dp" android:src="@drawable/ic_questoesmat" app:tint="#FFFFFF" />

                    <TextView
                        android:id="@+id/txtQuestMat"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="7dp"
                        android:fontFamily="@font/poppins"
                        android:gravity="center"
                        android:text="Questões\nMatemática"
                        android:textColor="@color/cor_texto"
                        android:textSize="12.5sp" />
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                    <ImageView android:id="@+id/btnQuestPort" android:layout_width="82dp" android:layout_height="82dp" android:background="@drawable/bg_botao_conteudo" android:clickable="true" android:focusable="true" android:foreground="?attr/selectableItemBackground" android:padding="19dp" android:src="@drawable/ic_questoesport" app:tint="#FFFFFF" />

                    <TextView
                        android:id="@+id/txtQuestPort"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="7dp"
                        android:fontFamily="@font/poppins"
                        android:gravity="center"
                        android:text="Questões\nPortuguês"
                        android:textColor="@color/cor_texto"
                        android:textSize="12.5sp" />
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                    <ImageView android:id="@+id/btnRedacao" android:layout_width="82dp" android:layout_height="82dp" android:background="@drawable/bg_botao_conteudo" android:clickable="true" android:focusable="true" android:foreground="?attr/selectableItemBackground" android:padding="19dp" android:src="@drawable/ic_redacao" app:tint="#FFFFFF" />

                    <TextView
                        android:id="@+id/txtRedacao"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="7dp"
                        android:fontFamily="@font/poppins"
                        android:gravity="center"
                        android:text="Redação"
                        android:textColor="@color/cor_texto"
                        android:textSize="12.5sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <View
            android:id="@+id/footer"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:background="@drawable/bg_bottom_menu"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <ImageButton android:id="@+id/btnHome" android:layout_width="48dp" android:layout_height="48dp" android:background="@android:color/transparent" android:contentDescription="Inicio" android:src="@drawable/ic_home" app:layout_constraintBottom_toBottomOf="@id/footer" app:layout_constraintEnd_toStartOf="@id/btnDesempenho" app:layout_constraintStart_toStartOf="@id/footer" app:layout_constraintTop_toTopOf="@id/footer" app:tint="#3A1E6C" />
        <ImageButton android:id="@+id/btnDesempenho" android:layout_width="48dp" android:layout_height="48dp" android:background="@android:color/transparent" android:contentDescription="Desempenho" android:src="@drawable/ic_desempenho" app:layout_constraintBottom_toBottomOf="@id/footer" app:layout_constraintEnd_toStartOf="@id/btnBuscar" app:layout_constraintStart_toEndOf="@id/btnHome" app:layout_constraintTop_toTopOf="@id/footer" app:tint="#FFFFFF" />
        <ImageButton android:id="@+id/btnBuscar" android:layout_width="48dp" android:layout_height="48dp" android:background="@android:color/transparent" android:contentDescription="Buscar" android:src="@drawable/ic_buscar" app:layout_constraintBottom_toBottomOf="@id/footer" app:layout_constraintEnd_toStartOf="@id/btnPerfil" app:layout_constraintStart_toEndOf="@id/btnDesempenho" app:layout_constraintTop_toTopOf="@id/footer" app:tint="#FFFFFF" />
        <ImageButton android:id="@+id/btnPerfil" android:layout_width="48dp" android:layout_height="48dp" android:background="@android:color/transparent" android:contentDescription="Perfil" android:src="@drawable/ic_user" app:layout_constraintBottom_toBottomOf="@id/footer" app:layout_constraintEnd_toEndOf="@id/footer" app:layout_constraintStart_toEndOf="@id/btnBuscar" app:layout_constraintTop_toTopOf="@id/footer" app:tint="#FFFFFF" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@drawable/bg_nav_drawer"
        app:headerLayout="@layout/nav_header"
        app:itemBackground="@drawable/bg_nav_item"
        app:itemIconTint="#DDD6FE"
        app:itemTextAppearance="@style/NavMenuTextStyle"
        app:itemTextColor="#FFFFFF"
        app:menu="@menu/menu_lateral" />

</androidx.drawerlayout.widget.DrawerLayout>
