<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:attr/windowBackground"    android:fitsSystemWindows="true">

    <!-- ===================== HEADER ===================== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/roxo_primario"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp">

        <ImageButton
            android:id="@+id/btnVoltar"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Voltar"
            android:src="@drawable/baseline_arrow_back_24"
            android:tint="@color/branco"
            tools:ignore="UseAppTint" />

        <TextView
            android:id="@+id/txtTituloDetalhe"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="40dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:fontFamily="@font/poppins_bold"
            android:gravity="center"
            android:maxLines="1"
            android:text="Geometria Plana"
            android:textColor="@color/branco"
            android:textSize="18sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- ===================== SIMULADOR DE VÍDEO DO YOUTUBE ===================== -->
    <!-- Fundo preto com logo do YouTube - TUDO clicável -->
    <LinearLayout
        android:id="@+id/layoutVideoSimulado"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:background="#000000"
        android:gravity="center"
        android:orientation="vertical"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground">

        <!-- Logo do YouTube centralizado -->
        <ImageView
            android:id="@+id/imgYoutubeLogo"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_youtube_logo"
            android:contentDescription="Assistir no YouTube"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

    <!-- ===================== RESUMO COM SCROLL ===================== -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="20dp"
            android:paddingBottom="16dp">

            <!-- Título da seção -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:fontFamily="@font/poppins_medium"
                android:text="Sobre este conteúdo"
                android:textColor="@color/roxo_primario"
                android:textSize="14sp"
                android:textStyle="bold" />

            <!-- Linha decorativa roxa -->
            <View
                android:layout_width="40dp"
                android:layout_height="3dp"
                android:background="@color/roxo_primario"
                android:layout_marginBottom="16dp" />

            <!-- Texto do resumo vindo do Firebase -->
            <TextView
                android:id="@+id/txtResumo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins"
                android:lineSpacingMultiplier="1.6"
                android:text="Carregando resumo..."
                android:textColor="?android:attr/textColorPrimary"
                android:textIsSelectable="true"
                android:textSize="15sp" />

        </LinearLayout>

    </ScrollView>

    <!-- ===================== RODAPÉ COM CHECKBOX E BOTÃO ===================== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="?attr/colorSurface"        android:elevation="8dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="16dp">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1A000000"
            android:layout_marginBottom="12dp" />

        <CheckBox
            android:id="@+id/checkVisto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:buttonTint="@color/roxo_primario"
            android:fontFamily="@font/poppins"
            android:text="Marcar como visto"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="15sp" />

        <Button
            android:id="@+id/btnQuestoes"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:backgroundTint="@color/roxo_primario"
            android:enabled="false"
            android:fontFamily="@font/poppins_medium"
            android:text="Responder Questões"
            android:textColor="@color/branco"
            android:textSize="15sp"
            android:textStyle="bold"
            app:cornerRadius="12dp" />

    </LinearLayout>

</LinearLayout>