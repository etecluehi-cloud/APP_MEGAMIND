<?xml version="1.0" encoding="utf-8"?>
<!-- Salve em: res/layout/item_nota.xml -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Data e hora -->
        <TextView
            android:id="@+id/txtDataHora"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/poppins"
            android:text="17/05/2025 • 14h32"
            android:textColor="#999999"
            android:textSize="11sp" />

        <!-- Título (tema) -->
        <TextView
            android:id="@+id/txtTituloNota"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="@font/poppins_bold"
            android:text="Educação Financeira nas Escolas"
            android:textColor="#1A1A2E"
            android:textSize="15sp" />

        <!-- Preview do texto -->
        <TextView
            android:id="@+id/txtPreviewNota"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:ellipsize="end"
            android:fontFamily="@font/poppins"
            android:maxLines="2"
            android:text="A falta de educação financeira no Brasil é um problema estrutural que afeta milhões de jovens..."
            android:textColor="#666666"
            android:textSize="13sp" />

        <!-- Botões de ação -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnVer"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:background="@drawable/bg_botao_ver"
                android:fontFamily="@font/poppins"
                android:text="👁 Ver"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp" />

            <Button
                android:id="@+id/btnCopiar"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_botao_copiar"
                android:fontFamily="@font/poppins"
                android:text="📋 Copiar"
                android:textColor="#7C3AED"
                android:textSize="12sp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp" />

            <Button
                android:id="@+id/btnExcluir"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_botao_excluir"
                android:fontFamily="@font/poppins"
                android:text="🗑 Excluir"
                android:textColor="#E53935"
                android:textSize="12sp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
