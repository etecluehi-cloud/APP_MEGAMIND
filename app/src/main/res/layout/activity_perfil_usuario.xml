<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"

    tools:context=".PerfilUsuario">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardPerfil"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="-120dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="1dp"
        app:cardBackgroundColor="@color/roxo_claro"

        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#AD7FFD"
            android:padding="10dp">

            <!-- foto de perfil -->
            <ImageView
                android:id="@+id/imgPerfil"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/bg_circulo_roxo"
                android:padding="12dp"
                android:src="@drawable/ic_user"

                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- nome do estudante -->
            <TextView
                android:id="@+id/txtNome"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:fontFamily="@font/poppins_medium"
                android:text="Nome do estudante"
                android:textColor="#FFFFFF"

                android:textSize="14sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toStartOf="@id/btnEditar"
                app:layout_constraintStart_toEndOf="@id/imgPerfil"
                app:layout_constraintTop_toTopOf="@id/imgPerfil" />

            <!-- @email do estudante -->
            <TextView
                android:id="@+id/txtEmail"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="/@estudante"
                android:textColor="#583497"

                app:layout_constraintEnd_toEndOf="@id/txtNome"
                app:layout_constraintStart_toStartOf="@id/txtNome"
                app:layout_constraintTop_toBottomOf="@id/txtNome" />

            <!-- botao editar e pontos -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEditar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="36dp"
                android:layout_marginEnd="1dp"
                android:fontFamily="@font/poppins_medium"
                android:minHeight="48dp"
                android:paddingVertical="6dp"
                android:text="Editar perfil"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"

                android:textSize="12sp"
                app:backgroundTint="#7B3FE4"
                app:cornerRadius="20dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:ignore="TouchTargetSizeCheck" />

            <TextView
                android:id="@+id/txtPontos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="⭐ 0 pts"

                android:textColor="#FFFFFF"
                app:layout_constraintStart_toStartOf="@id/txtNome"
                app:layout_constraintTop_toBottomOf="@id/txtEmail" />

            <TextView
                android:id="@+id/txtDias"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="🔥 0 dias"

                android:textColor="#FFFFFF"
                app:layout_constraintStart_toEndOf="@id/txtPontos"
                app:layout_constraintTop_toTopOf="@id/txtPontos" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- header -->
    <View
        android:id="@+id/header"
        android:layout_width="0dp"
        android:layout_height="210dp"
        android:background="@drawable/bg_header"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- scroll view p/ tela rolar -->


    <!-- footer -->

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/footer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cardPerfil"
        app:layout_constraintVertical_bias="0.0">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- configuraçoes e outros -->

            <!-- titulo da seção -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"
                android:fontFamily="@font/poppins_bold"
                android:text="CONFIGURAÇÕES"
                android:textColor="#A170FA"
                android:textSize="20sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_notificacao" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:fontFamily="@font/poppins"
                        android:text="Notificações" />

                    <Switch
                        android:id="@+id/switchNotifica"
                        android:layout_width="48dp"
                        android:layout_height="48dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_modoescuro" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:fontFamily="@font/poppins"
                        android:text="Modo escuro" />

                    <Switch
                        android:id="@+id/switchModoEscuro"
                        android:layout_width="48dp"
                        android:layout_height="48dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:id="@+id/lnlMetaDiaria"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_metadiaria" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:fontFamily="@font/poppins"
                        android:text="Meta diária" />

                    <ImageView
                        android:id="@+id/btnMetaDiaria"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_seta" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- título OUTROS -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="8dp"
                android:fontFamily="@font/poppins_bold"
                android:text="OUTROS"
                android:textColor="#A170FA"
                android:textSize="20sp"
                android:textStyle="bold" />

            <!-- sobre nós -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:id="@+id/lnlSobreNos"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_sobrenos" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:fontFamily="@font/poppins"
                        android:text="Sobre nós" />

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_seta" />
                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- fale conosco -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_faleconosco" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:fontFamily="@font/poppins"
                        android:text="Fale conosco" />

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_seta" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- logout -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:id="@+id/lnlSairConta"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_logout" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:fontFamily="@font/poppins"
                        android:text="Sair da conta"
                        android:textColor="#E53935" />

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_seta" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>


    </ScrollView>

    <View
        android:id="@+id/footer"
        android:layout_width="0dp"
        android:layout_height="80dp"
        android:background="@drawable/bg_bottom_menu"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <ImageButton
        android:id="@+id/btnHome"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@android:color/transparent"
        android:src="@drawable/ic_home"
        android:contentDescription="Início"
        app:tint="@color/icone_selecionado"

        app:layout_constraintBottom_toBottomOf="@id/footer"
        app:layout_constraintStart_toStartOf="@id/footer"
        app:layout_constraintEnd_toStartOf="@id/btnDesempenho"
        app:layout_constraintTop_toTopOf="@id/footer"/>

    <ImageButton
        android:id="@+id/btnDesempenho"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@android:color/transparent"
        android:src="@drawable/ic_desempenho"
        android:contentDescription="Desempenho"
        app:tint="@color/icone_selecionado"

        app:layout_constraintBottom_toBottomOf="@id/footer"
        app:layout_constraintStart_toEndOf="@id/btnHome"
        app:layout_constraintEnd_toStartOf="@id/btnBuscar"
        app:layout_constraintTop_toTopOf="@id/footer"/>

    <ImageButton
        android:id="@+id/btnBuscar"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@android:color/transparent"
        android:src="@drawable/ic_buscar"
        android:contentDescription="Buscar"
        app:tint="@color/icone_selecionado"

        app:layout_constraintBottom_toBottomOf="@id/footer"
        app:layout_constraintStart_toEndOf="@id/btnDesempenho"
        app:layout_constraintEnd_toStartOf="@id/btnPerfil"
        app:layout_constraintTop_toTopOf="@id/footer"/>

    <ImageButton
        android:id="@+id/btnPerfil"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@android:color/transparent"
        android:src="@drawable/ic_user"
        android:contentDescription="Perfil"
        app:tint="@color/icone_selecionado"

        app:layout_constraintBottom_toBottomOf="@id/footer"
        app:layout_constraintStart_toEndOf="@id/btnBuscar"
        app:layout_constraintEnd_toEndOf="@id/footer"
        app:layout_constraintTop_toTopOf="@id/footer"/>

    <TextView
        android:id="@+id/textView"
        android:layout_width="85dp"
        android:layout_height="40dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="16dp"
        android:fontFamily="@font/poppins_bold"
        android:text="Perfil"

        android:textColor="#FFFFFF"
        android:textSize="30sp"
        app:layout_constraintStart_toStartOf="@id/header"
        app:layout_constraintTop_toTopOf="@id/header" />

    <TextView
        android:id="@+id/textView2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/poppins"
        android:text="Gerencie sua conta e preferências"
        android:textColor="#FFFFFF"

        app:layout_constraintTop_toBottomOf="@id/textView"
        app:layout_constraintStart_toStartOf="@id/textView"
        android:layout_marginTop="4dp"/>

    <ImageView
        android:id="@+id/imgLogo2"
        android:layout_width="134dp"
        android:layout_height="164dp"
        android:layout_marginTop="0dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:srcCompat="@drawable/logo"
        android:elevation="12dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>