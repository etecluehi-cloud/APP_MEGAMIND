<?xml version="1.0" encoding="utf-8"?>
<!-- Salve em: res/layout/item_mensagem_bot.xml -->
<!-- Este layout serve para AMBOS os tipos de mensagem: bot (esquerda) e usuário (direita) -->
<!-- Você controla qual lado aparece pelo código Java (ver NotasAdapter) -->

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="4dp">

    <!-- Mensagem do BOT (lado esquerdo) -->
    <LinearLayout
        android:id="@+id/layoutMensagemBot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="start"
        android:orientation="horizontal"
        android:visibility="visible">

        <androidx.cardview.widget.CardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="60dp"
            android:background="?android:attr/windowBackground"
            app:cardCornerRadius="16dp"
            app:cardElevation="1dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:id="@+id/txtMensagemBot"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins"
                    android:text="Mensagem do bot aqui"
                    android:textColor="@color/cor_texto"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/txtHoraBot"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:layout_marginTop="4dp"
                    android:fontFamily="@font/poppins"
                    android:text="09:00"
                    android:textColor="?android:attr/textColorSecondary"
                    android:textSize="10sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    <!-- Mensagem do USUÁRIO (lado direito) -->
    <LinearLayout
        android:id="@+id/layoutMensagemUser"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:orientation="horizontal"
        android:visibility="gone"
        android:layout_marginTop="4dp">

        <androidx.cardview.widget.CardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="60dp"
            app:cardBackgroundColor="#7C3AED"
            app:cardCornerRadius="16dp"
            app:cardElevation="1dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:id="@+id/txtMensagemUser"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins"
                    android:text="Mensagem do usuário aqui"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/txtHoraUser"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:layout_marginTop="4dp"
                    android:fontFamily="@font/poppins"
                    android:text="09:05"
                    android:textColor="#D4B8FF"
                    android:textSize="10sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

</LinearLayout>
