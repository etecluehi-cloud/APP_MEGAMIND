<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E"
    tools:context=".ChatBot">

    <!-- HEADER do chat -->
    <androidx.cardview.widget.CardView
        android:id="@+id/headerChat"
        android:layout_width="0dp"
        android:layout_height="70dp"
        app:cardBackgroundColor="#7C3AED"
        app:cardCornerRadius="0dp"
        app:cardElevation="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- Botão Voltar -->
            <ImageButton
                android:id="@+id/btnVoltar"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="12dp"
                android:background="@android:color/transparent"
                android:contentDescription="Voltar"
                android:src="@drawable/ic_back"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@android:color/white" />

            <!-- Avatar do bot -->
            <ImageView
                android:id="@+id/imgBot"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_circulo_roxo_escuro"
                android:padding="6dp"
                android:src="@drawable/ic_chatbot"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/btnVoltar"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@android:color/white" />

            <!-- Nome e status -->
            <LinearLayout
                android:id="@+id/layoutNomeBot"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:orientation="vertical"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/btnOpcoes"
                app:layout_constraintStart_toEndOf="@id/imgBot"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins_bold"
                    android:text="Corretor IA"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/txtStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins"
                    android:text="● online • pronto para corrigir"
                    android:textColor="#C8B8FF"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- Botão opções -->
            <ImageButton
                android:id="@+id/btnOpcoes"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="12dp"
                android:background="@android:color/transparent"
                android:contentDescription="Opções"
                android:src="@drawable/ic_more_vert"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@android:color/white" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

    <!-- Lista de mensagens -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerMensagens"
        android:layout_width="411dp"
        android:layout_height="504dp"
        android:clipToPadding="false"
        android:paddingStart="12dp"
        android:paddingTop="8dp"
        android:paddingEnd="12dp"
        android:paddingBottom="8dp"
        app:layout_constraintBottom_toTopOf="@id/layoutInput"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerChat"
        tools:listitem="@layout/item_mensagem_bot" />

    <!-- Área de input -->
    <androidx.cardview.widget.CardView
        android:id="@+id/layoutInput"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="#7C3AED"
        app:cardCornerRadius="0dp"
        app:cardElevation="8dp"
        app:layout_constraintBottom_toTopOf="@id/footer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="10dp">

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp">

                <EditText
                    android:id="@+id/edtMensagem"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@android:color/transparent"
                    android:fontFamily="@font/poppins"
                    android:hint="Cole sua redação ou mensagem..."
                    android:inputType="textMultiLine|textCapSentences"
                    android:maxLines="4"
                    android:minHeight="44dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:textColor="#1A1A2E"
                    android:textColorHint="#AAAAAA"
                    android:textSize="13sp" />
            </androidx.cardview.widget.CardView>

            <!-- Botão enviar -->
            <ImageButton
                android:id="@+id/btnEnviar"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_botao_enviar"
                android:contentDescription="Enviar"
                android:padding="10dp"
                android:src="@drawable/ic_send"
                app:tint="@android:color/white" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- FOOTER igual à Home -->
    <View
        android:id="@+id/footer"
        android:layout_width="0dp"
        android:layout_height="80dp"
        android:background="@drawable/bg_bottom_menu"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageButton
        android:id="@+id/btnHome"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@android:color/transparent"
        android:contentDescription="Início"
        android:src="@drawable/ic_home"
        app:layout_constraintBottom_toBottomOf="@id/footer"
        app:layout_constraintEnd_toStartOf="@id/btnDesempenho"
        app:layout_constraintStart_toStartOf="@id/footer"
        app:layout_constraintTop_toTopOf="@id/footer"
        app:tint="@color/icone_selecionado" />

    <ImageButton
        android:id="@+id/btnDesempenho"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@android:color/transparent"
        android:contentDescription="Desempenho"
        android:src="@drawable/ic_desempenho"
        app:layout_constraintBottom_toBottomOf="@id/footer"
        app:layout_constraintEnd_toStartOf="@id/btnBuscar"
        app:layout_constraintStart_toEndOf="@id/btnHome"
        app:layout_constraintTop_toTopOf="@id/footer"
        app:tint="@color/icone_selecionado" />

    <ImageButton
        android:id="@+id/btnBuscar"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@android:color/transparent"
        android:contentDescription="Buscar"
        android:src="@drawable/ic_buscar"
        app:layout_constraintBottom_toBottomOf="@id/footer"
        app:layout_constraintEnd_toStartOf="@id/btnPerfil"
        app:layout_constraintStart_toEndOf="@id/btnDesempenho"
        app:layout_constraintTop_toTopOf="@id/footer"
        app:tint="@color/icone_selecionado" />

    <ImageButton
        android:id="@+id/btnPerfil"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@android:color/transparent"
        android:contentDescription="Perfil"
        android:src="@drawable/ic_user"
        app:layout_constraintBottom_toBottomOf="@id/footer"
        app:layout_constraintEnd_toEndOf="@id/footer"
        app:layout_constraintStart_toEndOf="@id/btnBuscar"
        app:layout_constraintTop_toTopOf="@id/footer"
        app:tint="@color/icone_selecionado" />

</androidx.constraintlayout.widget.ConstraintLayout>