<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="?attr/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp">

        <!-- Ícone -->
        <LinearLayout
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="#7B2FBE"
            android:gravity="center"
            android:layout_marginEnd="12dp">

            <TextView
                android:id="@+id/txtIcone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📚"
                android:textSize="14sp" />

        </LinearLayout>

        <!-- Nome + barra -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtNomeConteudo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mat. Básica"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtSubConteudo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 de 3 vídeos"
                android:textColor="?android:attr/textColorSecondary"
                android:textSize="11sp"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="4dp" />

            <ProgressBar
                android:id="@+id/progConteudo"
                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="5dp"
                android:progress="0"
                android:max="100"
                android:progressTint="#7B2FBE"
                android:progressBackgroundTint="#E0E0E0" />

        </LinearLayout>

        <!-- Porcentagem -->
        <TextView
            android:id="@+id/txtPorcentagem"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0%"
            android:textColor="#7B2FBE"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginStart="10dp" />

    </LinearLayout>
</androidx.cardview.widget.CardView>