<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:attr/windowBackground">

    <!-- Header roxo -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#7B2FBE"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="48dp"
        android:paddingBottom="16dp">

        <ImageButton
            android:id="@+id/btnVoltar"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@drawable/baseline_arrow_back_24"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="#FFFFFF"
            android:contentDescription="Voltar" />

        <TextView
            android:id="@+id/txtTituloConteudo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Geometria Plana"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginEnd="40dp"
            android:maxLines="1"
            android:ellipsize="end" />

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="16dp">

            <!-- Resumo -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RESUMO"
                android:textColor="#999999"
                android:textSize="11sp"
                android:letterSpacing="0.08"
                android:paddingStart="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="6dp" />

            <View
                android:layout_width="40dp"
                android:layout_height="3dp"
                android:background="#7B2FBE"
                android:layout_marginStart="16dp"
                android:layout_marginBottom="10dp" />

            <TextView
                android:id="@+id/txtResumo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Carregando..."
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.5"
                android:paddingStart="16dp"
                android:paddingEnd="16dp" />

            <!-- Vídeos -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VÍDEOS"
                android:textColor="#999999"
                android:textSize="11sp"
                android:letterSpacing="0.08"
                android:paddingStart="16dp"
                android:paddingTop="20dp"
                android:paddingBottom="6dp" />

            <View
                android:layout_width="40dp"
                android:layout_height="3dp"
                android:background="#7B2FBE"
                android:layout_marginStart="16dp"
                android:layout_marginBottom="10dp" />

            <!-- Vídeo 1 -->
            <LinearLayout
                android:id="@+id/lnlVideo1"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="?android:attr/windowBackground"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="44dp"
                    android:layout_height="30dp"
                    android:background="#000000"
                    android:gravity="center"
                    android:layout_marginEnd="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="▶"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Vídeo 1"
                        android:textColor="#7B2FBE"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/txtTituloVideo1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Assistir no YouTube"
                        android:textColor="?android:attr/textColorPrimary"
                        android:textSize="13sp"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <CheckBox
                    android:id="@+id/checkVideo1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="#7B2FBE" />

            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="0.5dp"
                android:background="?android:attr/listDivider"
                android:layout_marginStart="16dp" />

            <!-- Vídeo 2 -->
            <LinearLayout
                android:id="@+id/lnlVideo2"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="?android:attr/windowBackground"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="44dp"
                    android:layout_height="30dp"
                    android:background="#000000"
                    android:gravity="center"
                    android:layout_marginEnd="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="▶"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Vídeo 2"
                        android:textColor="#7B2FBE"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/txtTituloVideo2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Assistir no YouTube"
                        android:textColor="?android:attr/textColorPrimary"
                        android:textSize="13sp"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <CheckBox
                    android:id="@+id/checkVideo2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="#7B2FBE" />

            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="0.5dp"
                android:background="?android:attr/listDivider"
                android:layout_marginStart="16dp" />

            <!-- Vídeo 3 -->
            <LinearLayout
                android:id="@+id/lnlVideo3"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="?android:attr/windowBackground"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="44dp"
                    android:layout_height="30dp"
                    android:background="#000000"
                    android:gravity="center"
                    android:layout_marginEnd="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="▶"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Vídeo 3"
                        android:textColor="#7B2FBE"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/txtTituloVideo3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Assistir no YouTube"
                        android:textColor="?android:attr/textColorPrimary"
                        android:textSize="13sp"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <CheckBox
                    android:id="@+id/checkVideo3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="#7B2FBE" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Rodapé com progresso e botão questões -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="?attr/colorSurface"
        android:elevation="8dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="16dp">

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="?android:attr/listDivider"
            android:layout_marginBottom="10dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Progresso"
                android:textColor="?android:attr/textColorSecondary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/txtProgressoVideos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 de 3"
                android:textColor="#7B2FBE"
                android:textSize="12sp"
                android:textStyle="bold" />

        </LinearLayout>

        <ProgressBar
            android:id="@+id/progressVideos"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:layout_marginBottom="12dp"
            android:progress="0"
            android:max="100"
            android:progressTint="#7B2FBE"
            android:progressBackgroundTint="#E0E0E0" />

        <Button
            android:id="@+id/btnQuestoes"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Responder Questões"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:enabled="false"
            android:backgroundTint="#7B2FBE"
            app:cornerRadius="12dp" />

    </LinearLayout>

</LinearLayout>