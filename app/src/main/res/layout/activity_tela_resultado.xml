<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5"
    android:gravity="center">

    <!-- Cabeçalho roxo igual à TelaQuestoes -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#7B2FBE"
        android:gravity="center"
        android:layout_gravity="top">

        <TextView
            android:id="@+id/txtTituloResultado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Resultado"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Card central com os resultados -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingHorizontal="32dp">

        <!-- Ícone de troféu / conclusão -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎯"
            android:textSize="64sp"
            android:layout_marginBottom="24dp"/>

        <!-- Acertos -->
        <TextView
            android:id="@+id/txtAcertos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="✅  Acertos: 0 de 5"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#4CAF50"
            android:gravity="center"
            android:layout_marginBottom="12dp"/>

        <!-- Erros -->
        <TextView
            android:id="@+id/txtErros"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="❌  Erros: 0 de 5"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#F44336"
            android:gravity="center"
            android:layout_marginBottom="32dp"/>

        <!-- Divisor -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#DDDDDD"
            android:layout_marginBottom="32dp"/>

        <!-- Mensagem de desempenho -->
        <TextView
            android:id="@+id/txtDesempenho"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Bom trabalho!"
            android:textSize="16sp"
            android:textColor="#555555"
            android:gravity="center"
            android:layout_marginBottom="48dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnVoltarResultado"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Voltar ao Menu"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:backgroundTint="#7B2FBE"
            app:cornerRadius="12dp"
            xmlns:app="http://schemas.android.com/apk/res-auto"/>

    </LinearLayout>

</LinearLayout>