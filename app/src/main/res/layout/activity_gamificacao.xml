<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/windowBackground">

    <!-- ── HEADER GAMIFICAÇÃO ── -->
    <!-- Fundo roxo com altura compacta, sem copiar a Home -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_header"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingTop="36dp"
        android:paddingBottom="20dp"
        android:paddingHorizontal="24dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Ícone de troféu centralizado -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🏆"
            android:textSize="36sp"
            android:layout_marginBottom="4dp" />

        <!-- Título da tela -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/poppins_bold"
            android:text="Meu Progresso"
            android:textColor="@color/texto_principal"
            android:textSize="22sp" />

        <!-- Subtítulo dinâmico com o nome -->
        <TextView
            android:id="@+id/txtNomeU"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/poppins"
            android:text="Carregando..."
            android:textColor="#DDD6FE"
            android:textSize="14sp" />

    </LinearLayout>

    <!-- ── SCROLL CONTENT ── -->
    <ScrollView
        android:id="@+id/scrollContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="16dp"
        app:layout_constraintBottom_toTopOf="@id/footer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="12dp"
            android:paddingHorizontal="16dp">

            <!-- ── NÍVEL ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_bold"
                android:text="NÍVEL"
                android:textColor="@color/texto_principal"
                android:textSize="12sp"
                android:layout_marginBottom="6dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="?attr/colorSurface">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/txtNivel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/poppins_bold"
                            android:text="Nível 1"
                            android:textColor="@color/texto_principal"
                            android:textSize="16sp" />

                        <TextView
                            android:id="@+id/txtXpLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:fontFamily="@font/poppins"
                            android:text="· 0 / 100 XP"
                            android:textColor="?android:attr/textColorSecondary"
                            android:textSize="14sp" />

                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/progressXP"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="10dp"
                        android:layout_marginTop="10dp"
                        android:max="100"
                        android:progress="0"
                        android:progressTint="#7C3AED"
                        android:progressBackgroundTint="#EDE9FE" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── DIAS SEGUIDOS ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_bold"
                android:text="DIAS SEGUIDOS"
                android:textColor="@color/texto_principal"
                android:textSize="12sp"
                android:layout_marginBottom="6dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp"
                    android:background="?attr/colorSurface">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔥"
                        android:textSize="28sp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:id="@+id/txtDiasSeguidos"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/poppins_bold"
                            android:text="0 dias seguidos"
                            android:textColor="?android:attr/textColorPrimary"
                            android:textSize="16sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/poppins"
                            android:text="Continue assim!"
                            android:textColor="?android:attr/textColorSecondary"
                            android:textSize="12sp" />

                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── RANKING SEMANAL ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_bold"
                android:text="RANKING SEMANAL"
                android:textColor="@color/texto_principal"
                android:textSize="12sp"
                android:layout_marginBottom="6dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:id="@+id/layoutRanking"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:background="?attr/colorSurface">

                    <!-- Itens de ranking são inseridos via Java -->

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── BLOCO DE QUESTÕES ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_bold"
                android:text="BLOCO DE QUESTÕES"
                android:textColor="@color/texto_principal"
                android:textSize="12sp"
                android:layout_marginBottom="10dp" />

            <!-- Card Matemática -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardBlocoMat"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="#7C3AED"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🧮  Matemática"
                            android:fontFamily="@font/poppins_bold"
                            android:textColor="@color/texto_principal"
                            android:textSize="17sp"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="5 questões · ganhe +50 XP 🚀"
                            android:fontFamily="@font/poppins"
                            android:textColor="#D8B4FE"
                            android:textSize="12sp" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="→"
                        android:textColor="@color/texto_principal"
                        android:textSize="22sp"
                        android:layout_marginStart="12dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card Português -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardBlocoPort"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="#9333EA"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📖  Português"
                            android:fontFamily="@font/poppins_bold"
                            android:textColor="@color/texto_principal"
                            android:textSize="17sp"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="5 questões · ganhe +50 XP 🚀"
                            android:fontFamily="@font/poppins"
                            android:textColor="#E9D5FF"
                            android:textSize="12sp" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="→"
                        android:textColor="@color/texto_principal"
                        android:textSize="22sp"
                        android:layout_marginStart="12dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- ── RODAPÉ (igual ao Home) ── -->
    <View
        android:id="@+id/footer"
        android:layout_width="0dp"
        android:layout_height="80dp"
        android:background="@drawable/bg_bottom_menu"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageButton
        android:id="@+id/btnHome"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@android:color/transparent"
        android:contentDescription="Início"
        android:src="@drawable/ic_home"
        app:layout_constraintBottom_toBottomOf="@id/footer"
        app:layout_constraintEnd_toStartOf="@id/btnDesempenho"
        app:layout_constraintStart_toStartOf="@id/footer"
        app:layout_constraintTop_toTopOf="@id/footer"
        app:tint="#FFFFFF" />

    <ImageButton
        android:id="@+id/btnDesempenho"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@android:color/transparent"
        android:contentDescription="Desempenho"
        android:src="@drawable/ic_desempenho"
        app:layout_constraintBottom_toBottomOf="@id/footer"
        app:layout_constraintEnd_toStartOf="@id/btnBuscar"
        app:layout_constraintStart_toEndOf="@id/btnHome"
        app:layout_constraintTop_toTopOf="@id/footer"
        app:tint="#FFFFFF" />

    <ImageButton
        android:id="@+id/btnBuscar"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@android:color/transparent"
        android:contentDescription="Buscar"
        android:src="@drawable/ic_buscar"
        app:layout_constraintBottom_toBottomOf="@id/footer"
        app:layout_constraintEnd_toStartOf="@id/btnPerfil"
        app:layout_constraintStart_toEndOf="@id/btnDesempenho"
        app:layout_constraintTop_toTopOf="@id/footer"
        app:tint="#3A1E6C" />

    <ImageButton
        android:id="@+id/btnPerfil"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@android:color/transparent"
        android:contentDescription="Perfil"
        android:src="@drawable/ic_user"
        app:layout_constraintBottom_toBottomOf="@id/footer"
        app:layout_constraintEnd_toEndOf="@id/footer"
        app:layout_constraintStart_toEndOf="@id/btnBuscar"
        app:layout_constraintTop_toTopOf="@id/footer"
        app:tint="#FFFFFF" />

</androidx.constraintlayout.widget.ConstraintLayout>