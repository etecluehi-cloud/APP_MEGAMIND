<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/windowBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HEADER -->
        <LinearLayout
            android:id="@+id/header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#7B2FBE"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="48dp"
            android:paddingBottom="16dp">

            <ImageButton
                android:id="@+id/btnVoltar"
                android:layout_width="50dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Voltar"
                android:src="@drawable/baseline_arrow_back_24"
                app:tint="#FFFFFF" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="50dp"
                android:gravity="center"
                android:text="Conteúdo de Matemática"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Subtítulo -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Escolha um conteúdo"
            android:textColor="#7B2FBE"
            android:textSize="18sp"
            android:textStyle="bold"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="24dp"
            android:paddingBottom="8dp" />

        <!-- GRID DOS CARDS -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="8dp"
            android:paddingBottom="24dp"
            android:useDefaultMargins="true">

                <!-- Card 1: Matemática Básica -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardMatBasica"
                    android:layout_width="0dp"
                    android:layout_height="180dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp">

                    <LinearLayout
                        android:id="@+id/lnlMatBasica"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="#7B2FBE"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1"
                            android:textColor="#AAFFFFFF"
                            android:textSize="11sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Matemática\nBásica"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:layout_weight="1" />

                        <!-- Barra de progresso -->
                        <ProgressBar
                            android:id="@+id/progMatBasica"
                            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="5dp"
                            android:layout_marginTop="10dp"
                            android:progress="0"
                            android:max="100"
                            android:progressTint="#FFD700"
                            android:progressBackgroundTint="#33FFFFFF" />

                        <TextView
                            android:id="@+id/txtProgMatBasica"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="0 de 3 vídeos"
                            android:textColor="#AAFFFFFF"
                            android:textSize="9sp" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Card 2: Porcentagem -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardPorcentagem"
                    android:layout_width="0dp"
                    android:layout_height="180dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp">

                    <LinearLayout
                        android:id="@+id/lnlPorcentagem"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="#9B59B6"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="2"
                            android:textColor="#AAFFFFFF"
                            android:textSize="11sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Porcentagem"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:layout_weight="1" />

                        <ProgressBar
                            android:id="@+id/progPorcentagem"
                            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="5dp"
                            android:layout_marginTop="10dp"
                            android:progress="0"
                            android:max="100"
                            android:progressTint="#FFD700"
                            android:progressBackgroundTint="#33FFFFFF" />

                        <TextView
                            android:id="@+id/txtProgPorcentagem"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="0 de 3 vídeos"
                            android:textColor="#AAFFFFFF"
                            android:textSize="9sp" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Card 3: Álgebra -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardAlgebra"
                    android:layout_width="0dp"
                    android:layout_height="180dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp">

                    <LinearLayout
                        android:id="@+id/lnlAlgebra"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="#7B2FBE"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="3"
                            android:textColor="#AAFFFFFF"
                            android:textSize="11sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Álgebra"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:layout_weight="1" />

                        <ProgressBar
                            android:id="@+id/progAlgebra"
                            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="5dp"
                            android:layout_marginTop="10dp"
                            android:progress="0"
                            android:max="100"
                            android:progressTint="#FFD700"
                            android:progressBackgroundTint="#33FFFFFF" />

                        <TextView
                            android:id="@+id/txtProgAlgebra"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="0 de 3 vídeos"
                            android:textColor="#AAFFFFFF"
                            android:textSize="9sp" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Card 4: Funções -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardFuncoes"
                    android:layout_width="0dp"
                    android:layout_height="180dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp">

                    <LinearLayout
                        android:id="@+id/lnlFuncoes"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="#9B59B6"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="4"
                            android:textColor="#AAFFFFFF"
                            android:textSize="11sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Funções"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:layout_weight="1" />

                        <ProgressBar
                            android:id="@+id/progFuncoes"
                            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="5dp"
                            android:layout_marginTop="10dp"
                            android:progress="0"
                            android:max="100"
                            android:progressTint="#FFD700"
                            android:progressBackgroundTint="#33FFFFFF" />

                        <TextView
                            android:id="@+id/txtProgFuncoes"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="0 de 3 vídeos"
                            android:textColor="#AAFFFFFF"
                            android:textSize="9sp" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Card 5: Geometria Plana -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardGeometriaPlana"
                    android:layout_width="0dp"
                    android:layout_height="180dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp">

                    <LinearLayout
                        android:id="@+id/lnlGeoPlana"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="#7B2FBE"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="5"
                            android:textColor="#AAFFFFFF"
                            android:textSize="11sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Geometria\nPlana"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:layout_weight="1" />

                        <ProgressBar
                            android:id="@+id/progGeoPlana"
                            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="5dp"
                            android:layout_marginTop="10dp"
                            android:progress="0"
                            android:max="100"
                            android:progressTint="#FFD700"
                            android:progressBackgroundTint="#33FFFFFF" />

                        <TextView
                            android:id="@+id/txtProgGeoPlana"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="0 de 3 vídeos"
                            android:textColor="#AAFFFFFF"
                            android:textSize="9sp" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Card 6: Geometria Espacial -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardGeometriaEspacial"
                    android:layout_width="0dp"
                    android:layout_height="180dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp">

                    <LinearLayout
                        android:id="@+id/lnlGeoEsp"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="#9B59B6"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="6"
                            android:textColor="#AAFFFFFF"
                            android:textSize="11sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Geometria\nEspacial"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:layout_weight="1" />

                        <ProgressBar
                            android:id="@+id/progGeoEsp"
                            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="5dp"
                            android:layout_marginTop="10dp"
                            android:progress="0"
                            android:max="100"
                            android:progressTint="#FFD700"
                            android:progressBackgroundTint="#33FFFFFF" />

                        <TextView
                            android:id="@+id/txtProgGeoEsp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="0 de 3 vídeos"
                            android:textColor="#AAFFFFFF"
                            android:textSize="9sp" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Card 7: Grandezas e Medidas -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardGrandezasMedidas"
                    android:layout_width="0dp"
                    android:layout_height="180dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp">

                    <LinearLayout
                        android:id="@+id/lnlGrandezasMedidas"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="#7B2FBE"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="7"
                            android:textColor="#AAFFFFFF"
                            android:textSize="11sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Grandezas\ne Medidas"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:layout_weight="1" />

                        <ProgressBar
                            android:id="@+id/progGrandezas"
                            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="5dp"
                            android:layout_marginTop="10dp"
                            android:progress="0"
                            android:max="100"
                            android:progressTint="#FFD700"
                            android:progressBackgroundTint="#33FFFFFF" />

                        <TextView
                            android:id="@+id/txtProgGrandezas"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="0 de 3 vídeos"
                            android:textColor="#AAFFFFFF"
                            android:textSize="9sp" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Card 8: Estatística -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardEstatistica"
                    android:layout_width="0dp"
                    android:layout_height="180dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp">

                    <LinearLayout
                        android:id="@+id/lnlEstatistica"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="#9B59B6"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="8"
                            android:textColor="#AAFFFFFF"
                            android:textSize="11sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Estatística"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:layout_weight="1" />

                        <ProgressBar
                            android:id="@+id/progEstatistica"
                            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="5dp"
                            android:layout_marginTop="10dp"
                            android:progress="0"
                            android:max="100"
                            android:progressTint="#FFD700"
                            android:progressBackgroundTint="#33FFFFFF" />

                        <TextView
                            android:id="@+id/txtProgEstatistica"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="0 de 3 vídeos"
                            android:textColor="#AAFFFFFF"
                            android:textSize="9sp" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Card 9: Probabilidade -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardProbabilidade"
                    android:layout_width="0dp"
                    android:layout_height="180dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp">

                    <LinearLayout
                        android:id="@+id/lnlProbabilidade"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="#7B2FBE"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="9"
                            android:textColor="#AAFFFFFF"
                            android:textSize="11sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Probabilidade"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:layout_weight="1" />

                        <ProgressBar
                            android:id="@+id/progProbabilidade"
                            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="5dp"
                            android:layout_marginTop="10dp"
                            android:progress="0"
                            android:max="100"
                            android:progressTint="#FFD700"
                            android:progressBackgroundTint="#33FFFFFF" />

                        <TextView
                            android:id="@+id/txtProgProbabilidade"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="0 de 3 vídeos"
                            android:textColor="#AAFFFFFF"
                            android:textSize="9sp" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Card 10: Matemática Financeira -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardMatFinanceira"
                    android:layout_width="0dp"
                    android:layout_height="180dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp">

                    <LinearLayout
                        android:id="@+id/lnlMatFinanceira"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="#9B59B6"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="10"
                            android:textColor="#AAFFFFFF"
                            android:textSize="11sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Matemática\nFinanceira"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:layout_weight="1" />

                        <ProgressBar
                            android:id="@+id/progMatFinanceira"
                            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="5dp"
                            android:layout_marginTop="10dp"
                            android:progress="0"
                            android:max="100"
                            android:progressTint="#FFD700"
                            android:progressBackgroundTint="#33FFFFFF" />

                        <TextView
                            android:id="@+id/txtProgMatFinanceira"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="0 de 3 vídeos"
                            android:textColor="#AAFFFFFF"
                            android:textSize="9sp" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </GridLayout>

    </LinearLayout>
</ScrollView>