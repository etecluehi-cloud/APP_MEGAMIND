<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:attr/windowBackground">

    <!-- ===== HEADER + PROGRESSO ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#7B2FBE"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="48dp"
        android:paddingBottom="16dp">

        <!-- Linha do título -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="14dp">

            <ImageButton
                android:id="@+id/btnVoltar"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@drawable/baseline_arrow_back_24"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="#FFFFFF"
                android:contentDescription="Voltar" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Metas do dia"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginEnd="40dp" />

        </LinearLayout>

        <!-- Barra de progresso -->
        <ProgressBar
            android:id="@+id/progressMetas"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:progress="0"
            android:max="100"
            android:progressTint="#FFD700"
            android:progressBackgroundTint="#5B1A9E"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/txtProgressoMetas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="0 de 0 concluídas"
            android:textColor="#CCFFFFFF"
            android:textSize="11sp"
            android:gravity="center" />

    </LinearLayout>

    <!-- ===== CONTEÚDO COM SCROLL ===== -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="16dp">

            <!-- Seção: Pendentes -->
            <TextView
                android:id="@+id/lblPendentes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="PENDENTES"
                android:textColor="#999999"
                android:textSize="11sp"
                android:letterSpacing="0.08"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="8dp" />

            <!-- Lista de metas pendentes -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerPendentes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:clipToPadding="false" />

            <!-- Mensagem lista vazia -->
            <TextView
                android:id="@+id/txtSemPendentes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🎉 Nenhuma meta pendente!"
                android:textColor="#AAAAAA"
                android:textSize="13sp"
                android:gravity="center"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:visibility="gone" />

            <!-- Seção: Concluídas -->
            <TextView
                android:id="@+id/lblConcluidas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="CONCLUÍDAS"
                android:textColor="#999999"
                android:textSize="11sp"
                android:letterSpacing="0.08"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="8dp" />

            <!-- Lista de metas concluídas -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerConcluidas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:clipToPadding="false"
                android:alpha="0.6" />

            <!-- Mensagem sem concluídas -->
            <TextView
                android:id="@+id/txtSemConcluidas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nenhuma meta concluída ainda."
                android:textColor="#AAAAAA"
                android:textSize="13sp"
                android:gravity="center"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:visibility="gone" />

        </LinearLayout>
    </ScrollView>

    <!-- ===== RODAPÉ: ADICIONAR META ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="?attr/colorSurface"
        android:elevation="8dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp">

        <EditText
            android:id="@+id/edtNovaMeta"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:hint="Adicionar nova meta..."
            android:textSize="14sp"
            android:background="@drawable/bg_campo_senha"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:maxLines="2"
            android:layout_marginEnd="10dp" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabAdicionarMeta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@android:drawable/ic_input_add"
            app:backgroundTint="#7B2FBE"
            app:tint="#FFFFFF"
            app:fabSize="mini"
            android:contentDescription="Adicionar meta" />

    </LinearLayout>

</LinearLayout>